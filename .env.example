# Supabase — create dev + prod projects at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Prisma / Database
# DATABASE_URL: Supabase Transaction Pooler (port 6543) — used by the app at runtime.
#   Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# DIRECT_URL: Supabase Session Pooler (port 5432, pooler hostname) — used by
#   `prisma db push` / `prisma migrate` from CI and Vercel builds.
#   IMPORTANT: do NOT use the raw direct host `db.<ref>.supabase.co:5432` here —
#   that endpoint is IPv6-only and Vercel's build infra cannot reach it
#   (you'll see `P1001: Can't reach database server at db.<ref>.supabase.co:5432`).
#   The session pooler is IPv4-reachable and supports the DDL that db push needs.
#   Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=
DIRECT_URL=

# PostHog — https://app.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry — https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# P3.3A — production GLB athlete asset gates. Set to '1' on the prod
# Vercel environment to render the license-clean GLB athlete and the
# imported closeout / back-cut animation clips. Defaults to off
# everywhere; the runtime falls back to procedural figures when off.
# See `docs/qa/production-glb-loading.md` for the full QA flow.
NEXT_PUBLIC_USE_GLB_ATHLETE_PREVIEW=
NEXT_PUBLIC_USE_IMPORTED_CLOSEOUT_CLIP=
NEXT_PUBLIC_USE_IMPORTED_BACK_CUT_CLIP=

# Email — Gmail SMTP (generate an App Password at myaccount.google.com → Security → App Passwords)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM="CourtIQ <you@gmail.com>"

# Cron security — any random secret string, passed as Authorization: Bearer <secret>
CRON_SECRET=change-me-to-a-random-string
