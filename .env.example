# Supabase — create dev + prod projects at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Prisma / Database (use Supabase Transaction Pooler connection string)
DATABASE_URL=

# PostHog — https://app.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry — https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email — Gmail SMTP (generate an App Password at myaccount.google.com → Security → App Passwords)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM="CourtIQ <you@gmail.com>"

# Cron security — any random secret string, passed as Authorization: Bearer <secret>
CRON_SECRET=change-me-to-a-random-string
