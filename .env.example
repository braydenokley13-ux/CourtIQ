# Sentry
NEXT_PUBLIC_SENTRY_DSN="https://your-dsn@sentry.io/your-project"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"
SENTRY_ORG="your-org"
SENTRY_PROJECT="courtiq-web"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
