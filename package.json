{
  "name": "courtiq",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": "22.x",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "prisma:validate": "turbo run prisma:validate",
    "db:push": "pnpm --filter @courtiq/db exec prisma db push",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "seed:scenarios": "pnpm exec tsx scripts/seed-scenarios.ts",
    "seed:lessons": "pnpm exec tsx scripts/seed-lessons.ts",
    "seed:content": "pnpm seed:scenarios && pnpm seed:lessons",
    "qa:auth": "pnpm exec tsx scripts/playwright-auth-setup.ts",
    "qa:screenshot": "pnpm exec tsx scripts/screenshot-scenario.ts",
    "qa:scene:screenshots": "pnpm exec tsx scripts/screenshot-scene-phase-f.ts",
    "screenshot:bdw": "SCENARIO=BDW-01 pnpm exec tsx scripts/screenshot-scenario.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "zod": "^3.24.1"
  }
}
