  "tactical": {
    "cue_atoms": ["hand_in_lane"],
    "primary_defender_slot": "deny_def",
    "user_slot_default": "corner_shooter",
    "teaching_point": "Late clock + denial = baseline backdoor. The corner is the only catch the defense can't recover to.",
    "common_miss_reason": "Players hold the corner spot waiting for the swing because the C&S is the natural finish on a swing-rotation. With the clock under 8, the defender knows the swing is coming and pre-commits to the lane. The cutter has to read that pre-commit and punish it before the clock decides for them.",
    "why_best_read_works": "The denying defender's hand-in-lane stance is closed off to the rim. A baseline back-cut puts the cutter behind the help-side rotation before x4 can rotate up; the lead pass lands at the rim with the shot clock buying the window.",
    "lesson_connection": "backdoor-window",
    "difficulty_default": 3
  },

