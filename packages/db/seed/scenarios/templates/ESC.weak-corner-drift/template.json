  "tactical": {
    "cue_atoms": ["stunt_and_recover", "hips_turned_to_ball"],
    "primary_defender_slot": "stunt_def",
    "user_slot_default": "drifter",
    "teaching_point": "When your defender stunts at the ball, slide wider on the arc. The kickout lane opens, and his closeout has to cover a longer distance.",
    "common_miss_reason": "Weak-side shooters hold their spot waiting for the kickout. The stunt only buys a half-second window — if the shooter doesn't widen, the defender recovers before the pass can arrive clean.",
    "why_best_read_works": "The stunt commits the defender's hips and weight to the ball. A drift wider on the arc moves the catch point further from his recovery path — the pass arrives clean and the closeout is too long to contest the shot.",
    "lesson_connection": "empty-space-cut",
    "difficulty_default": 2,
    "mirror_safety": "symmetric"
  },

